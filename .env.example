# Supabase — create a project at https://supabase.com and copy these from Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# Groq — create a free key at https://console.groq.com → API Keys
# (Replaces Gemini — no billing required, free tier, ultra-fast inference)
GROQ_API_KEY=your-groq-api-key-here

# Optional: set this to your deployed Vercel URL for chatbot tool-handler internal fetches
# NEXT_PUBLIC_SITE_URL=https://your-project.vercel.app
